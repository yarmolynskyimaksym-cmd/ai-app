generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  notes     Note[]
  bugs      Bug[]
  posts     Post[]
  messages  Message[]
  templates PromptTemplate[]
  updates   AnalyticsUpdate[]
}

model Agent {
  id           String   @id @default(cuid())
  agencyId     String?  @unique
  name         String
  status       String   @default("active")
  region       String?
  tier         String?
  healthScore  String   @default("⚪")
  wauCurrent   Float    @default(0)
  wauPrev      Float    @default(0)
  regCurrent   Float    @default(0)
  regPrev      Float    @default(0)
  dauYesterday Float    @default(0)
  dauPrev7d    Float    @default(0)
  regYesterday Float    @default(0)
  regPrev7d    Float    @default(0)
  metricCurrent Float   @default(0)
  metricPrev    Float   @default(0)
  period        String  @default("")
  aiSummary     String?
  updatedAt     DateTime @updatedAt
}

model Bug {
  id         String   @id @default(cuid())
  externalId String?  @unique
  title      String
  body       String
  author     String
  channel    String
  priority   String   @default("medium")
  status     String   @default("new")
  source     String   @default("slack")
  caseCount  Int      @default(1)
  tag        String   @default("New")
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  externalId String?  @unique
  channel    String
  author     String
  text       String
  receivedAt DateTime @default(now())
  severity   String?
  category   String?
  isQuestion Boolean  @default(false)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Note {
  id        String    @id @default(cuid())
  raw       String
  action    String?
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
}

model Post {
  id             String    @id @default(cuid())
  prompt         String
  content        String
  network        String    @default("instagram")
  status         String    @default("draft")
  scheduledAt    DateTime?
  externalPostId String?
  userId         String
  user           User      @relation(fields: [userId], references: [id])
}

model PromptTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  promptText   String
  outputFormat String   @default("markdown")
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  updates      AnalyticsUpdate[]
}

model AnalyticsUpdate {
  id         String          @id @default(cuid())
  inputData  String
  result     String
  format     String          @default("markdown")
  createdAt  DateTime        @default(now())
  templateId String?
  template   PromptTemplate? @relation(fields: [templateId], references: [id])
  userId     String
  user       User            @relation(fields: [userId], references: [id])
}
