# Postgres (Neon або Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NextAuth — згенеруй: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Anthropic Claude API — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot Token — від @BotFather (опційно — без нього mock)
TELEGRAM_BOT_TOKEN=

# Post Bridge API Key — post-bridge.com → Settings → API (опційно)
POSTBRIDGE_API_KEY=

# Amplitude (опційно — без нього mock)
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=
AMPLITUDE_EVENT=agent_action
AMPLITUDE_GROUP_BY=agent_name
